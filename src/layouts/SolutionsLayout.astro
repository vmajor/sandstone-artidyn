---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/foundations/elements/Text.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <section class="bg-base-100">
    <Wrapper variant="wide" class="pt-4 pb-20">
      <div class="relative rounded-[2.5rem] h-[60vh] lg:h-[75vh] overflow-hidden mb-16 shadow-2xl">
        {frontmatter.image && (
          <Image
            width={1920}
            height={1080}
            loading="eager"
            decoding="async"
            alt={frontmatter.image.alt}
            src={frontmatter.image.url}
            class="object-cover size-full absolute inset-0"
          />
        )}
        <div class="absolute inset-0 bg-linear-to-t from-base-900/60 to-transparent"></div>

        <div class="absolute bottom-12 left-12 right-12 flex flex-col md:flex-row md:items-end justify-between gap-8">
          <div class="max-w-2xl">
            <Text
              tag="h1"
              variant="displayLG"
              class="text-white font-bold tracking-tight mb-4"
            >
              {frontmatter.title}
            </Text>
            <Text
              tag="p"
              variant="textLG"
              class="text-base-200 tracking-normal text-pretty"
            >
              {frontmatter.description}
            </Text>
          </div>

          {frontmatter.category && (
            <div class="bg-white/10 backdrop-blur-md border border-white/20 px-6 py-3 rounded-full shrink-0">
              <Text tag="span" variant="textSM" class="text-white font-medium uppercase tracking-widest">
                Tier: {frontmatter.category}
              </Text>
            </div>
          )}
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 px-4">
        {/* Content Column */}
        <div class="lg:col-span-8 lg:col-start-1">
          <Wrapper variant="prose" class="prose-lg md:prose-xl">
            <slot />
          </Wrapper>
        </div>

        {/* Info/CTA Column */}
        <div class="lg:col-span-4 flex flex-col gap-8">
          <div class="bg-base-50 p-10 rounded-[2rem] border border-base-200 sticky top-32">
            <Text tag="h3" variant="displayXS" class="text-base-900 font-bold mb-6">
              Inquire about this Solution
            </Text>
            <Text tag="p" variant="textMD" class="text-base-600 mb-8">
              Every Artidyn deployment is tailored to your specific architectural and operational requirements.
            </Text>

            <a
              href="/contact/"
              class="inline-flex items-center justify-center w-full bg-base-900 text-white py-5 px-8 rounded-2xl font-bold hover:bg-base-800 transition-all shadow-lg hover:shadow-base-900/20 active:scale-[0.98]"
            >
              Get a Proposal
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>

            <div class="mt-10 pt-10 border-t border-base-200 space-y-6">
              <div>
                <Text tag="p" variant="textXS" class="text-base-400 uppercase font-bold tracking-widest mb-2">
                  Typical Lead Time
                </Text>
                <Text tag="p" variant="textMD" class="text-base-900 font-medium">
                  8-12 Weeks from Order
                </Text>
              </div>
              <div>
                <Text tag="p" variant="textXS" class="text-base-400 uppercase font-bold tracking-widest mb-2">
                  Support
                </Text>
                <Text tag="p" variant="textMD" class="text-base-900 font-medium">
                  24/7 Remote Monitoring & Local Servicing
                </Text>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
