---
// Assets
// Foundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/foundations/elements/Text.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";

const { frontmatter } = Astro.props;

// 1. ALL SPECS (For the main 2-column table)
const allSpecs = [
  { label: "Price", value: frontmatter.price ? `$${frontmatter.price.toLocaleString()}` : null },
  { label: "Dimensions", value: frontmatter.dimensions },
  { label: "Weight", value: frontmatter.weight },
  { label: "Kinematics", value: frontmatter.kinematics },
  { label: "Espresso Unit", value: frontmatter.espressoUnit },
  { label: "Power", value: frontmatter.power },
  { label: "Production Time", value: frontmatter.productionTime },
  { label: "Throughput", value: frontmatter.throughput },
  { label: "Cup Capacity", value: frontmatter.cupCapacity },
  { label: "Recipes", value: frontmatter.recipes },
  { label: "Syrups", value: frontmatter.syrups },
  { label: "Toppings", value: frontmatter.toppings },
  { label: "Ice Capacity", value: frontmatter.iceCapacity },
  { label: "Milk Refrigeration", value: frontmatter.milkRefrigeration },
  { label: "Frothing Temp", value: frontmatter.milkFrothingTemp },
  { label: "Cleaning System", value: frontmatter.cleaningSystem },
  { label: "Latte Art / Print", value: frontmatter.latteArt },
  { label: "Display", value: frontmatter.display },
  { label: "Payment Systems", value: frontmatter.paymentSystems?.join(", ") },
  { label: "Fleet Management", value: frontmatter.fleetManagement },
  { label: "Mobility", value: frontmatter.mobility },
  { label: "Certifications", value: frontmatter.certifications?.join(", ") },
  { label: "Enclosure", value: frontmatter.enclosureType },
].filter(spec => spec.value);

// 2. QUICK SPECS (For the sticky sidebar)
const quickSpecLabels = ["Price", "Dimensions", "Weight", "Power", "Throughput"];
const quickSpecs = allSpecs.filter(spec => quickSpecLabels.includes(spec.label));

const gallery = frontmatter.gallery || [];
---

<BaseLayout>
  <section>
    <Wrapper variant="wide" class="pt-4 pb-8">
      <div class="relative rounded-3xl min-h-[500px] h-fit overflow-hidden bg-base-100">
        {frontmatter.cover && (
          <img
            width={1440}
            height={1080}
            loading="eager"
            decoding="async"
            alt={frontmatter.cover.alt}
            src={frontmatter.cover.url}
            class="object-contain max-h-[800px] w-auto mx-auto object-center p-8 lg:p-16"
          />
        )}

        <div class="absolute bottom-4 left-4 right-4 max-w-sm flex flex-col">
          <div class="p-8 bg-white/80 backdrop-blur-md rounded-2xl w-fit border border-base-200 shadow-xl">
            <div class="mb-4">
               <a href="/projects" class="text-xs font-bold uppercase tracking-widest text-base-400 hover:text-base-900 transition-colors">← Back to Catalog</a>
            </div>
            <div>
              <Text
                tag="h1"
                variant="textLG"
                class="text-base-900 tracking-tight 2xl:text-2xl text-balance font-medium"
              >
                {frontmatter.title}
              </Text>
              <div class="space-y-1 mt-8">
                <Text tag="p" variant="textSM" class="text-base-600 font-bold uppercase tracking-wider">
                  {frontmatter.category?.replace("-", " ")}
                </Text>
                <Text tag="p" variant="textSM" class="text-base-500">
                  {frontmatter.location}
                </Text>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>

  <section>
    <Wrapper variant="standard" class="py-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        
        {/* LEFT COLUMN: Main Content & Full Specs */}
        <div class="lg:col-span-2 space-y-12">
          
          <div class="prose prose-base max-w-none text-base-500">
            <slot />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {frontmatter.features && (
              <div>
                <Text tag="h3" variant="textBase" class="font-bold mb-4 uppercase tracking-wider text-base-900">Key Features</Text>
                <ul class="space-y-2">
                  {frontmatter.features.map(feature => (
                    <li class="flex items-center gap-2 text-base-500">
                      <span class="size-1.5 rounded-full bg-base-300"></span>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {frontmatter.scenarios && (
              <div>
                <Text tag="h3" variant="textBase" class="font-bold mb-4 uppercase tracking-wider text-base-900">Best For</Text>
                <ul class="space-y-2">
                  {frontmatter.scenarios.map(scenario => (
                    <li class="flex items-center gap-2 text-base-500">
                      <span class="size-1.5 rounded-full bg-base-300"></span>
                      {scenario}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>

          {/* Specifications Table */}
          <div class="p-8 rounded-2xl bg-base-50 border border-base-200 mt-12 shadow-sm">
            <Text tag="h3" variant="textBase" class="font-bold mb-6 uppercase tracking-wider text-base-900">Full Specifications</Text>
            <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
              {allSpecs.map(spec => (
                <div class="flex flex-col border-b border-base-200 pb-2">
                  <dt class="text-xs text-base-400 uppercase font-medium">{spec.label}</dt>
                  <dd class="text-sm text-base-700 font-medium">{spec.value}</dd>
                </div>
              ))}
            </dl>
          </div>

          {/* Enhanced Product Gallery */}
          {gallery.length > 0 && (
            <div class="space-y-8 mt-12">
              <Text tag="h3" variant="textBase" class="font-bold uppercase tracking-wider text-base-900">Product Gallery</Text>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                {gallery.map((image, index) => (
                  <>
                  <button
                    class="group relative aspect-square overflow-hidden rounded-2xl bg-base-50 border border-base-100 p-2 cursor-zoom-in"
                    onclick={`document.getElementById('gallery-dialog-${index}').showModal()`}
                  >
                    <img
                      alt={image.alt || `Project image ${index + 1}`}
                      src={image.url}
                      width={400}
                      height={400}
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-110"
                    />
                    <div class="absolute inset-0 bg-base-900/0 group-hover:bg-base-900/5 transition-colors duration-300"></div>
                  </button>

                  <dialog
                    id={`gallery-dialog-${index}`}
                    class="backdrop:bg-base-900/80 backdrop:backdrop-blur-sm p-0 rounded-3xl border-none bg-transparent max-w-[95vw] max-h-[95vh] overflow-hidden"
                  >
                    <div class="relative bg-white p-4 md:p-8 rounded-3xl shadow-2xl flex flex-col items-center">
                      <button
                        onclick={`this.closest('dialog').close()`}
                        class="absolute top-4 right-4 size-10 flex items-center justify-center rounded-full bg-base-100 text-base-900 hover:bg-base-200 transition-colors z-10"
                        aria-label="Close"
                      >
                        ✕
                      </button>
                      <div class="max-h-[80vh] overflow-auto">
                        <img
                          alt={image.alt || `Project image ${index + 1}`}
                          src={image.url}
                          width={1600}
                          height={1200}
                          class="max-h-[75vh] w-auto object-contain rounded-xl"
                        />
                      </div>
                      {image.alt && (
                        <Text tag="p" variant="textSM" class="mt-4 text-base-500 font-medium">
                          {image.alt}
                        </Text>
                      )}
                    </div>
                    <form method="dialog" class="fixed inset-0 -z-10">
                      <button class="size-full cursor-default"><span class="sr-only">Close</span></button>
                    </form>
                  </dialog>
                  </>
                ))}
              </div>
            </div>
          )}
        </div>

        {/* RIGHT COLUMN: Sticky At-a-Glance Sidebar */}
        <div class="lg:sticky lg:top-24 h-fit">
          <div class="p-8 rounded-2xl bg-base-50 border border-base-200 shadow-sm">
            <Text tag="h3" variant="textBase" class="font-bold mb-6 uppercase tracking-wider text-base-900">At A Glance</Text>
            <dl class="space-y-4">
              {quickSpecs.map(spec => (
                <div class="flex flex-col border-b border-base-200 pb-2 last:border-0">
                  <dt class="text-xs text-base-400 uppercase font-medium">{spec.label}</dt>
                  <dd class="text-sm text-base-700 font-medium">{spec.value}</dd>
                </div>
              ))}
            </dl>
            
            <div class="mt-8 pt-6 border-t border-base-200">
              <a href="/contact" class="flex w-full items-center justify-center rounded-xl bg-base-900 px-4 py-3 text-sm font-semibold text-white hover:bg-base-800 transition-all shadow-sm uppercase tracking-widest text-[10px] active:scale-[0.98]">
                 Request More Information
              </a>
            </div>
          </div>
        </div>
        
      </div>
    </Wrapper>
  </section>
</BaseLayout>
