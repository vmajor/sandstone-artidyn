---
// Assets
import { Image } from "astro:assets";
// Foundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/foundations/elements/Text.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
// Load content tools
import { getEntry } from "astro:content";

// 1. Get the slug from the URL (e.g., 'sylvia-wu')
const teamSlug = Astro.url.pathname.split("/").filter(Boolean).pop();

// 2. Fetch the actual collection entry. 
// This triggers your config.ts schema, which calculates the native image sizes for us.
const teamMember = await getEntry("team", teamSlug);

// Safety check: fall back to props if getEntry fails (though it shouldn't if URLs are correct)
const data = teamMember ? teamMember.data : Astro.props.frontmatter;
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="pt-32 pb-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
        <div class="lg:col-span-1">
          <div class="p-8 bg-base-100 rounded-2xl w-full sticky top-24">
            
            <div class="mb-8 rounded-xl overflow-hidden">
               <Image
                 src={data.image.url} 
                 alt={data.image.alt}
                 class="w-full h-auto object-cover"
               />
            </div>
            <div>
              <Text
                tag="h2"
                variant="textLG"
                class="text-base-600 tracking-tight 2xl:text-2xl text-balance font-medium"
              >
                {data.name}
              </Text>
              <Text
                tag="p"
                variant="textSM"
                class="text-base-600 tracking-tight text-pretty 2xl:text-2xl mt-2"
              >
                {data.role}
              </Text>
              <div class="space-y-4 mt-8">
                {
                  data.bio.split("\n").map((paragraph) => (
                    <Text
                      tag="p"
                      variant="textBase"
                      class="text-base-600 tracking-tight text-pretty 2xl:text-2xl"
                    >
                      {paragraph}
                    </Text>
                  ))
                }
              </div>
            </div>
            <div class="flex flex-col gap-1 text-xs text-base-600 mt-auto pt-8">
              <a href={data.socials.twitter} aria-label="X"> Twitter </a>
              <a href={data.socials.linkedin} aria-label="LinkedIn">
                Linkedin
              </a>
              <a href={data.socials.email} aria-label="Email"> Email </a>
              <a href={data.socials.website} aria-label="Website">
                Website
              </a>
            </div>
          </div>
        </div>
      </div>
      <Wrapper
        variant="prose"
        class="max-w-xl mx-auto mt-8 text-base-600 space-y-4 space-x-4"
        ><slot /></Wrapper
      >
    </Wrapper>
  </section>
</BaseLayout>