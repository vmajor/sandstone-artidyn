---
// Assets
// import Logo from "@/components/assets/Logo.astro"; // <-- You can remove this import now
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Content
import { getCollection } from "astro:content";
const team = await getCollection("team");
---

<footer class="overflow-hidden">
  <Wrapper variant="wide" class="py-4">
    <div class="relative rounded-3xl h-[calc(100vh-2rem)] overflow-hidden">
      <video
        autoplay
        muted
        loop
        playsinline
        class="object-cover size-full absolute inset-0 object-center"
      >
        <source src="/footer.mp4" type="video/mp4" />
        Your browser does not support the video tag.
      </video>

      <div class="absolute inset-0 z-0 pointer-events-none opacity-20">
    <svg class="invisible size-0">
        <filter id="noiseFilter">
            <feTurbulence 
                type="fractalNoise" 
                baseFrequency="0.6" 
                stitchTiles="stitch" 
            />
        </filter>
    </svg>
    <div 
        class="size-full" 
        style="filter: url(#noiseFilter);"
    ></div>
</div>

      <div class="relative lg:max-w-xl lg:ml-auto flex flex-col h-full">
        <div
          class="p-8 bg-base-100 m-4 rounded-2xl h-full justify-between flex flex-col"
        >
          <div>
            <img 
              src="/artidyn_corporate_green_logo.svg" 
              alt="Artidyn Robotics" 
              class="w-48 h-auto" 
            />

            <a href="/team" class="mt-12 block">
              {
                team.map((member, index) => (
                  <>
                    <Text
                      tag="h3"
                      variant="textBase"
                      class="text-base-900 font-medium leading-relaxed 2xl:text-2xl"
                      class:list={index > 0 ? "mt-4" : ""}
                    >
                      {member.data.role}
                    </Text>
                    <Text
                      tag="p"
                      variant="textXS"
                      class="text-base-500 font-medium tracking-tight 2xl:text-lg"
                    >
                      {member.data.name}
                    </Text>
                  </>
                ))
              }
            </a>
            <div class="mt-8 lg:mt-12">
              <Text
                tag="p"
                variant="textLG"
                class="text-base-600 tracking-tight text-pretty 2xl:text-2xl"
              >
                Ready to Build Your New Automated Business?
                <br />
                <br />
                Let our experts help you choose the right certified robot for your goals. 
                We don't just sell machines, we provide the business model to ensure you thrive. 
              </Text>
            </div>
            <Text
              tag="p"
              variant="textSM"
              class="text-base-600 tracking-tight text-pretty 2xl:text-xl mt-4"
            >
              We are the antithesis of the "wild west." Every robot we sell is vetted, tested, 
              and backed by the Artidyn Seal of Quality. 
            </Text>
          </div>

          <Text tag="p" variant="textXS" class="text-base-500">
             © {new Date().getFullYear()} Artidyn Robotics LLC, Sheridan Wyoming USA. All rights reserved.
          </Text>
        </div>
      </div>
    </div>
  </Wrapper>
</footer>