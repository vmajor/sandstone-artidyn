---
import { Image } from "astro:assets";
// Foundations
import Text from "@/components/foundations/elements/Text.astro";
import Kicker from "@/components/foundations/elements/Kicker.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import RollingLink from "@/components/foundations/elements/RollingLink.astro";
// Content
import { getCollection } from "astro:content";
import one from "@/assets/images/solutions/1.png";
import two from "@/assets/images/solutions/2.png";
import three from "@/assets/images/solutions/3.png";

const allSolutions = await getCollection("solutions");

const sortedSolutions = allSolutions
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .slice(0, 3);
const solutionImages = [
  one,
  two,
  three
];
---

<footer class="overflow-hidden">
  <Wrapper variant="wide" class="py-4">
    <div class="relative rounded-3xl h-[calc(100vh-2rem)] overflow-hidden">
      <div>
        {
          solutionImages.map((img, index) => (
            <Image
              id={`solution-image-${index}`}
              src={img}
              alt={sortedSolutions[index]?.data.title}
              width={1440}
              height={1440}
              class="object-cover size-full absolute inset-0 object-center"
              style={`display: ${index === 0 ? "block" : "none"}`}
            />
          ))
        }
      </div>
      <div class="relative lg:max-w-xl lg:ml-auto flex flex-col h-full">
        <div
          class="p-8 bg-base-100 m-4 rounded-2xl h-full justify-between flex flex-col"
        >
          <Kicker copy="Automation Solutions" />
          <Text
            tag="p"
            variant="displaySM"
            class="text-base-900 font-medium tracking-tight lg:text-balance mt-12"
          >
           Explore our range of certified beverage robots. Whether your goal is maximum volume or a premium craft experience, we have a solution tailored to your vision.
          </Text>
          <div class="divide-y border-y divide-base-200 border-base-200 mt-8">
            {
              sortedSolutions.map((solution, index) => (
                <button
                  class={`text-left w-full group transition-all text-base-900 py-2  ${index === 0 ? "" : "opacity-50"}`}
                  data-solution-index={index}
                >
                  <Text
                    tag="p"
                    variant="textLG"
                    class="font-medium group-focus:translate-x-4 duration-500 ease-in-out transition-all"
                  >
                    {solution.data.title}
                  </Text>
                </button>
              ))
            }
          </div>
          <Text
            tag="p"
            variant="textBase"
            class="text-base-600 text-balance mt-8"
            id="active-description"
          >
            {sortedSolutions[0]?.data.description}
          </Text>
          <RollingLink
            href="/products/"
            variant="light"
            hoverText="View The Robots"
            initialText="See All Certified Models"
            class="mt-8"
          />
        </div>
      </div>
    </div>
  </Wrapper>
</footer>
<script define:vars={{ sortedSolutions }}>
  window.sortedSolutions = sortedSolutions;
  const buttons = document.querySelectorAll("[data-solution-index]");
  const images = document.querySelectorAll("[id^='solution-image-']");
  const descriptionEl = document.getElementById("active-description");
  buttons.forEach((button, index) => {
    button.addEventListener("click", () => {
      // Update active tab
      buttons.forEach((btn, i) => {
        if (i === index) {
          btn.classList.remove("opacity-50");
        } else {
          btn.classList.add("opacity-50");
        }
      });
      // Update visible image
      images.forEach((img, i) => {
        img.style.display = i === index ? "block" : "none";
      });
      // Update description
      descriptionEl.textContent = window.sortedSolutions[index].data.description;
    });
  });
</script>
