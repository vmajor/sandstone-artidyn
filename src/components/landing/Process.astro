---
// Assets
//  // import one from "@/images/services/1.png";
//  // import two from "@/images/services/2.png";
//  // import three from "@/images/services/3.png";
// // Keeping these imports to avoid build errors, but they are unused in the array below
//  // import implementationImg from "@/images/services/4.png";
//  // import five from "@/images/services/5.png";
//  // import six from "@/images/services/6.png";

// Foundations
import Text from "@/components/foundations/elements/Text.astro";
import Kicker from "@/components/foundations/elements/Kicker.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";

const processSteps = [
  {
    title: "Discovery Consultation",
    description:
      "We start with a free call to understand your business goals, ideal locations, and budget. We assess your specific constraints—staffing, space, or throughput—to define the problem.",
    image: "/images/services/1.png",
  },
  {
    title: "Tailored Solution",
    description:
      "We match you with the perfect robot from our Certified Range. No guesswork—just transparent pricing, clear ROI projections, and a system vetted for your specific use case.",
    image: "/images/services/2.png",
  },
  {
    title: "Launch & Support",
    description:
      "We guide you through delivery, installation, customization, and training. We ensure your team is ready and your robot is calibrated for 24/7 reliability from Day 1.",
    image: "/images/services/3.png",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div>
        <div
          class="p-8 bg-white rounded-xl lg:sticky lg:top-24 max-w-sm flex flex-col"
        >
          <Kicker copy="The Process" />
          <Text
            tag="h3"
            variant="textXLG"
            class="text-base-900 text-balance mt-12 font-medium"
          >
            We are invested in your success. Our 3-step process is designed to ensure you not only launch an automated business, but thrive.
          </Text>
        </div>
      </div>
      <div
        class="lg:col-span-2 divide-y divide-base-200 border-y border-base-200"
      >
        {
          processSteps.map((step, index) => (
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4 py-8 lg:sticky lg:top-0 bg-base-100">
              <Text
                tag="p"
                variant="display2XL"
                class="text-base-900 font-semibold  italic"
              >
                0{index + 1}.
              </Text>
              <div class="lg:col-span-2 text-balance">
                <Text
                  tag="h3"
                  variant="displaySM"
                  class="text-base-900 font-medium tracking-tight lg:text-balance"
                >
                  {step.title}
                </Text>
                <Text tag="p" variant="textSM" class="text-base-600 mt-2">
                  {step.description}
                </Text>
              </div>
              <div class="w-full h-48 bg-base-200 rounded-xl flex items-center justify-center overflow-hidden">
                <img
                  src={step.image}
                  alt={step.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
