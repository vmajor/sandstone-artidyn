---
import Text from "@/components/foundations/elements/Text.astro";

interface Props {
  variant?: "info" | "warning" | "success" | "base";
  title?: string;
  class?: string;
}

const { variant = "base", title, class: className } = Astro.props;

const variants = {
  info: "bg-blue-50 border-blue-200 text-blue-800",
  warning: "bg-amber-50 border-amber-200 text-amber-800",
  success: "bg-emerald-50 border-emerald-200 text-emerald-800",
  base: "bg-base-50 border-base-200 text-base-800",
};

const iconColors = {
  info: "text-blue-500",
  warning: "text-amber-500",
  success: "text-emerald-500",
  base: "text-base-500",
};
---

<div class:list={["p-6 border rounded-2xl my-8 flex gap-4 items-start", variants[variant], className]}>
  <div class:list={["mt-1 shrink-0", iconColors[variant]]}>
    {variant === "info" && (
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
    )}
    {variant === "warning" && (
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
    )}
    {variant === "success" && (
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
    )}
    {variant === "base" && (
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
    )}
  </div>
  <div class="flex-1">
    {title && (
      <Text tag="h4" variant="textMD" class="font-bold mb-1 uppercase tracking-wider">
        {title}
      </Text>
    )}
    <div class="prose prose-sm max-w-none">
      <slot />
    </div>
  </div>
</div>
