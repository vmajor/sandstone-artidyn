---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Text from "@/components/foundations/elements/Text.astro";

interface Props {
  category: "high-volume" | "craft" | "compact";
}

const { category } = Astro.props;

const allProducts = await getCollection("products");
const filteredProducts = allProducts.filter(
  (product) => product.data.category === category || product.data.status === category
);
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-12">
  {filteredProducts.map((product) => (
    <a
      href={`/products/${product.slug}/`}
      class="group flex flex-col bg-base-50 rounded-3xl overflow-hidden border border-base-200 hover:border-base-900 transition-colors duration-300"
    >
      <div class="aspect-[4/3] overflow-hidden">
        <Image
          src={product.data.cover.url}
          alt={product.data.cover.alt}
          width={800}
          height={600}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </div>
      <div class="p-8 flex flex-col flex-1">
        <Text tag="h4" variant="displayXS" class="text-base-900 font-medium mb-2">
          {product.data.title}
        </Text>
        <Text tag="p" variant="textSM" class="text-base-600 line-clamp-3 mb-6 flex-1">
          {product.body.substring(0, 150)}...
        </Text>
        <div class="flex items-center justify-between pt-4 border-t border-base-200 mt-auto">
          <Text tag="span" variant="textSM" class="font-bold text-base-900">
             ${product.data.price?.toLocaleString()} USD
          </Text>
          <span class="text-base-900 group-hover:translate-x-1 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
        </div>
      </div>
    </a>
  ))}
</div>
