---
// Assets
import { Image } from "astro:assets";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";

const { name, role, image, bio, socials } = {
  name: Astro.props.post.data.name,
  role: Astro.props.post.data.role,
  image: Astro.props.post.data.image.url,
  bio: Astro.props.post.data.bio,
  socials: Astro.props.post.data.socials,
};

// Map keys to pretty labels
const socialLabels = {
  linkedin: "LinkedIn",
  twitter: "X (Twitter)",
  github: "GitHub",
  huggingface: "Hugging Face",
  email: "Email",
  website: "Website",
};
---

<article class="flex flex-col h-full">
  
  <div class="w-full flex justify-center rounded-2xl overflow-hidden mb-8">
    <Image
      src={image}
      alt={name}
      class="max-w-full h-auto rounded-2xl object-contain"
    />
  </div>

  <div class="flex flex-col flex-grow">
    
    <div class="mb-6">
      <Text tag="h3" variant="textLG" class="text-base-900 font-medium">
        {name}
      </Text>
      <Text tag="p" variant="textSM" class="text-base-500 mt-1 uppercase tracking-wide">
        {role}
      </Text>
    </div>

    <div class="space-y-4 text-pretty">
      {
        bio && bio.split("\n").map((paragraph) => (
          paragraph.trim() && (
            <Text
              tag="p"
              variant="textBase"
              class="text-base-600 tracking-tight"
            >
              {paragraph}
            </Text>
          )
        ))
      }
    </div>

    {socials && (
      <div class="mt-auto pt-4 pb-8 border-t border-base-200 flex flex-wrap gap-x-6 gap-y-2 text-xs font-medium text-base-500 uppercase tracking-wider">
        {Object.entries(socials).map(([key, url]) => (
            url && (
            <a 
              href={key === 'email' ? `mailto:${url}` : url} 
              target={key === 'email' ? undefined : "_blank"}
              rel={key === 'email' ? undefined : "noopener noreferrer"}
              class="hover:text-base-900 transition-colors"
            >
              {socialLabels[key] || key}
            </a>
            )
        ))}
      </div>
    )}
  </div>
</article>