---
// Foundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/foundations/elements/Text.astro";
import Kicker from "@/components/foundations/elements/Kicker.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
// Components
import ServicesCard from "@/components/services/ServiceCard.astro";
// Content
import { getCollection } from "astro:content";
const allServices = await getCollection("services");

// Sort by Title (Compact, Craft, High-Volume) or keep default
const sortedServices = allServices.sort((a, b) => 
  a.data.title.localeCompare(b.data.title)
);
---

<BaseLayout>
  <section>
    <section>
      <Wrapper variant="standard" class="pt-32 pb-12">
        {/* LITERAL HEADER: Focused on Scalability and Business Needs */}
        <Text
          tag="h1"
          variant="displayXL"
          class="text-base-900 font-medium tracking-tight lg:indent-42 text-pretty"
        >
          Scalable <span class="text-base-500 font-light italic"
            >automation solutions</span
          > tailored to your specific <span
            class="text-base-500 font-light italic">volume requirements</span
          > and <span class="text-base-500 font-light italic"
            >business model</span
          >.
        </Text>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mt-12 lg:mt-24">
          <div>
            <div
              class="p-8 bg-white rounded-xl lg:sticky lg:top-24 max-w-sm flex flex-col"
            >
              {/* CHANGED: 'The Process' -> 'The Strategy' to avoid confusion with your new /process route */}
              <Kicker copy="The Strategy" />
              <Text
                tag="h3"
                variant="textXLG"
                class="text-base-900 text-balance mt-12 font-medium"
              >
                We don't believe in one-size-fits-all. Our certified robots are categorized by throughput, footprint, and specialty to ensure the right ROI for your location.
              </Text>
            </div>
          </div>
          <div
            class="lg:col-span-2 divide-y divide-base-200 border-y border-base-200"
          >
            {sortedServices.map((service) => <ServicesCard post={service} />)}
          </div>
        </div>
      </Wrapper>
    </section>
  </section>
</BaseLayout>