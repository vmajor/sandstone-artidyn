---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import ProjectCardBig from "@/components/projects/ProjectCardBig.astro";
// Content
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");

// 1. DEFINE THE TIERS (The "Predefined Categories")
// This controls the display order on the page.
const tiers = [
  {
    id: "compact", // Matches the 'category' field in your Markdown
    label: "Compact Series",
    description: "Small footprint solutions for kiosks and offices."
  },
  {
    id: "high-volume",
    label: "High-Volume Production",
    description: "Maximum throughput for stadiums, airports, and cafeterias."
  },
  {
    id: "craft",
    label: "Premium Craft",
    description: "Artisan-level quality for luxury hospitality."
  }
];

// 2. GROUPING LOGIC
// We create a function to fetch and sort robots for a specific tier.
function getRobotsForTier(tierId) {
  return allProjects
    .filter((project) => project.data.category === tierId)
    // Sort by Price (Low to High), or fallback to Title if no price exists
    .sort((a, b) => (a.data.price || 0) - (b.data.price || 0));
}
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="pt-32 pb-8">
      <Text
        tag="h1"
        variant="displayXL"
        class="text-base-900 font-medium tracking-tight lg:indent-42 text-pretty"
      >
        Explore our <span class="text-base-500 font-light italic"
          >certified range</span
        > of high-performance <span class="text-base-500 font-light italic"
          >beverage robots</span
        > engineered for <span
          class="text-base-500 font-light italic">automated retail</span
        >.
      </Text>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mt-12 lg:mt-24">
        
        <div class="hidden lg:block lg:col-span-3">
          <div class="lg:sticky lg:top-24">
            <Kicker copy="Catalog Categories" />
            <nav>
              <ul class="divide-y border-y divide-base-200 border-base-200 mt-12">
                {
                  tiers.map((tier) => (
                    <li>
                      <a
                        href={`#category-${tier.id}`}
                        class="font-medium hover:translate-x-4 duration-500 ease-in-out transition-all py-3 text-lg flex justify-between items-center group"
                      >
                        {tier.label}
                        <span class="text-xs text-base-400 opacity-0 group-hover:opacity-100 transition-opacity">
                          ↓
                        </span>
                      </a>
                    </li>
                  ))
                }
              </ul>
            </nav>
          </div>
        </div>

        <div class="lg:col-span-9 flex flex-col gap-y-32">
          {
            tiers.map((tier) => {
              const robots = getRobotsForTier(tier.id);
              
              // Only render the section if there are robots in this category
              if (robots.length === 0) return null; 

              return (
                <div id={`category-${tier.id}`} class="scroll-mt-32">
                  
                  {/* Category Header */}
                  <div class="mb-12 border-b border-base-200 pb-8">
                    <Text tag="h2" variant="displaySM" class="text-base-900 mb-2">
                      {tier.label}
                    </Text>
                    <Text tag="p" variant="textBase" class="text-base-500">
                      {tier.description}
                    </Text>
                  </div>

                  {/* Grid of Robots in this Category */}
                  <div class="grid grid-cols-1 gap-y-24">
                    {robots.map((robot) => (
                      <ProjectCardBig post={robot} />
                    ))}
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>