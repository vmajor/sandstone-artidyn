---
import SolutionsLayout from "@/layouts/SolutionsLayout.astro";
import { getCollection } from "astro:content";
import RollingLink from "@/components/foundations/elements/RollingLink.astro";

export async function getStaticPaths() {
  const solutions = await getCollection("solutions");
  const paths = solutions.map((page) => {
    return {
      params: { slug: page.slug },
      props: { page },

    };
  });
  return paths;
}
const { page } = Astro.props;
const { Content } = await page.render();
---

<SolutionsLayout frontmatter={page.data}>
  <Content />
  
  {/* THE BRIDGE: Connecting the Solution Tier to the Robot Catalog */}
  <div class="mt-12 pt-8 border-t border-base-200">
    <RollingLink
      href={page.data.category ? `/products/#category-${page.data.category}` : "/products/"}
      variant="primary"
      initialText="View Certified Robots"
      hoverText="Open Catalog"
    />
  </div>
</SolutionsLayout>
