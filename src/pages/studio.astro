---
// Foundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/foundations/elements/Text.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="pt-32 pb-2">
      {/* LITERAL HEADER: Who you are */}
      <Text
        tag="h1"
        variant="displayXL"
        class="text-base-900 font-medium tracking-tight lg:indent-42 text-pretty"
      >
        Artidyn is a <span class="text-base-500 font-light italic"
          >specialized partner</span
        > in beverage automation, helping businesses deploy <span class="text-base-500 font-light italic"
          >certified robotics</span
        > to increase margin, <span
          class="text-base-500 font-light italic">efficiency</span
        >, and <span class="text-base-500 font-light italic">consistency</span>.
      </Text>
      
      {/* LITERAL BODY COPY: B2B Focused */}
      <div
        class="columns-1 md:columns-2 lg:columns-4 mt-8 text-base-600 space-y-4 space-x-4"
      >
        <Text tag="p" variant="textSM">
          Founded to bridge the gap between hardware manufacturers and retail operators, Artidyn Robotics curates the world's most reliable automated beverage solutions.
        </Text>
        <Text tag="p" variant="textSM" class="mt-4">
          We do not just resell hardware. We engineer the implementation. Our team assesses your foot traffic, menu requirements, and operational flow to match you with the correct automation tier.
        </Text>
        <Text tag="p" variant="textSM">
          With a focus on high-volume airports, busy lobbies, and 24/7 retail environments, we provide the technical certification and support needed to ensure ROI from day one.
        </Text>
        <Text tag="p" variant="textSM">
          Our methodology moves beyond the novelty of robotics and focuses on the utility: reducing labor costs, eliminating waste, and delivering a perfect pour, every single time.
        </Text>
      </div>
    </Wrapper>
    
    <Wrapper variant="wide" class="pb-12">
      <div
        class="relative overflow-hidden mt-12 rounded-3xl h-[calc(100vh-2rem)] items-end justify-end flex lg:items-start lg:justify-start"
      >
        {/* Replace /studio.mp4 with a video of a robot working or a static image if no video exists yet */}
        <video
          autoplay
          muted
          loop
          playsinline
          class="object-cover size-full absolute inset-0 object-center"
        >
          <source src="/studio.mp4" type="video/mp4" />
           Your browser does not support the video tag.
        </video>
      </div>
    </Wrapper>
  </section>
</BaseLayout>