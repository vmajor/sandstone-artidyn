---
import Logo from "@/components/assets/Logo.astro";
// Foundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/foundations/elements/Text.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import Footer from "@/components/global/Footer.astro";
---

<BaseLayout hideFooter={Footer}>
  <section class="overflow-hidden">
    <Wrapper variant="wide" class="py-4">
      <div class="relative rounded-3xl h-[calc(100vh-2rem)] overflow-hidden">
        <video
          autoplay
          muted
          loop
          playsinline
          class="object-cover size-full absolute inset-0 object-center"
        >
          <source src="/contact.mp4" type="video/mp4" />
          Your browser does not support the video tag.
        </video>

        <div class="relative lg:max-w-xl lg:ml-auto flex flex-col h-full">
          <div
            class="p-8 bg-white m-4 rounded-2xl h-full overflow-y-auto"
          >
            <div>
              <a href="/">
                <Logo
                  class="text-base tracking-tighter uppercase focus:outline-none text-base-900 font-semibold"
                />
              </a>
              <Text
                tag="h1"
                variant="textLG"
                class="text-base-600 tracking-tight 2xl:text-2xl text-balance mt-8 font-medium"
              >
                Schedule a Consultation
              </Text>
              <Text tag="p" variant="textSM" class="text-base-500 mt-2">
                Let's discuss how Artidyn's beverage robots can uncap your business growth.
              </Text>

              <form
                id="contact-form"
                name="contact"
                method="POST"
                data-netlify="true"
                class="mt-8 space-y-4"
              >
                <input type="hidden" name="form-name" value="contact" />
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="name" class="block text-xs font-bold text-base-900 uppercase tracking-wider mb-1">Full Name</label>
                    <input type="text" name="name" id="name" required class="w-full bg-base-50 border border-base-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-base-900 transition-all" placeholder="John Doe" />
                  </div>
                  <div>
                    <label for="company" class="block text-xs font-bold text-base-900 uppercase tracking-wider mb-1">Company</label>
                    <input type="text" name="company" id="company" required class="w-full bg-base-50 border border-base-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-base-900 transition-all" placeholder="Artidyn Corp" />
                  </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="email" class="block text-xs font-bold text-base-900 uppercase tracking-wider mb-1">Business Email</label>
                    <input type="email" name="email" id="email" required class="w-full bg-base-50 border border-base-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-base-900 transition-all" placeholder="john@example.com" />
                  </div>
                  <div>
                    <label for="industry" class="block text-xs font-bold text-base-900 uppercase tracking-wider mb-1">Industry</label>
                    <select name="industry" id="industry" required class="w-full bg-base-50 border border-base-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-base-900 transition-all appearance-none">
                      <option value="">Select Industry</option>
                      <option value="hospitality">Hospitality</option>
                      <option value="retail">Retail</option>
                      <option value="corporate">Corporate Office</option>
                      <option value="healthcare">Healthcare</option>
                      <option value="education">Education</option>
                      <option value="other">Other</option>
                    </select>
                  </div>
                </div>

                <div>
                  <label for="timeline" class="block text-xs font-bold text-base-900 uppercase tracking-wider mb-1">Product Timeline</label>
                  <select name="timeline" id="timeline" required class="w-full bg-base-50 border border-base-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-base-900 transition-all appearance-none">
                    <option value="">Select Timeline</option>
                    <option value="immediate">Immediate (1-3 months)</option>
                    <option value="planning">Planning (3-6 months)</option>
                    <option value="future">Future exploration (6+ months)</option>
                  </select>
                </div>

                <div>
                  <label for="message" class="block text-xs font-bold text-base-900 uppercase tracking-wider mb-1">Message</label>
                  <textarea name="message" id="message" rows="4" required class="w-full bg-base-50 border border-base-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-base-900 transition-all resize-none" placeholder="How can we help you?"></textarea>
                </div>

                <button type="submit" id="submit-button" class="w-full bg-base-900 text-white font-bold uppercase tracking-widest text-xs py-4 rounded-xl hover:bg-base-800 transition-all shadow-lg active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
                  <span id="button-text">Send Inquiry</span>
                  <span id="button-loader" class="hidden">Sending...</span>
                </button>
              </form>

              <div class="mt-12 pt-8 border-t border-base-100 flex flex-col sm:flex-row justify-between items-start gap-8">
                <div>
                   <Text tag="p" variant="textXS" class="text-base-900 font-bold uppercase tracking-wider">Connect</Text>
                   <a href="https://www.linkedin.com/company/artidyn-robotics-llc/" target="_blank" rel="noopener noreferrer" class="text-base-500 hover:text-base-900 block text-xs mt-2 transition-colors">
                     LinkedIn
                   </a>
                </div>
                <div>
                   <Text tag="p" variant="textXS" class="text-base-900 font-bold uppercase tracking-wider">Email</Text>
                   <a href="mailto:hi@artidyn.ai" class="text-base-500 hover:text-base-900 block text-xs mt-2 transition-colors">
                     hi@artidyn.ai
                   </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>

  <dialog id="status-modal" class="backdrop:bg-base-900/50 backdrop:backdrop-blur-sm rounded-2xl p-0 shadow-2xl border-0 overflow-hidden max-w-sm w-full">
    <div class="p-8 text-center">
      <div id="modal-icon-success" class="hidden mx-auto size-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
        </svg>
      </div>
      <div id="modal-icon-error" class="hidden mx-auto size-16 bg-red-100 text-red-600 rounded-full flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </div>

      <h3 id="modal-title" class="text-xl font-bold text-base-900 mb-2">Message Sent</h3>
      <p id="modal-message" class="text-base-500 text-sm mb-6">Thank you for reaching out. We'll get back to you shortly.</p>

      <button onclick="document.getElementById('status-modal').close()" class="w-full bg-base-900 text-white font-bold uppercase tracking-widest text-xs py-3 rounded-xl hover:bg-base-800 transition-all">
        Dismiss
      </button>
    </div>
  </dialog>
</BaseLayout>

<script is:inline>
  const form = document.getElementById('contact-form');
  const modal = document.getElementById('status-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalMessage = document.getElementById('modal-message');
  const modalIconSuccess = document.getElementById('modal-icon-success');
  const modalIconError = document.getElementById('modal-icon-error');
  const submitButton = document.getElementById('submit-button');
  const buttonText = document.getElementById('button-text');
  const buttonLoader = document.getElementById('button-loader');

  let autoCloseTimeout;

  const showModal = (isSuccess) => {
    modalIconSuccess.classList.toggle('hidden', !isSuccess);
    modalIconError.classList.toggle('hidden', isSuccess);

    if (isSuccess) {
      modalTitle.innerText = "Inquiry Received";
      modalMessage.innerText = "Thank you for reaching out. An Artidyn specialist will contact you shortly.";
      form.reset();
    } else {
      modalTitle.innerText = "Submission Failed";
      modalMessage.innerText = "We encountered an error. Please try again or email us directly at hi@artidyn.ai.";
    }

    modal.showModal();

    // Auto-close after 5 seconds
    clearTimeout(autoCloseTimeout);
    autoCloseTimeout = setTimeout(() => {
      modal.close();
    }, 5000);
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // UI Loading State
    submitButton.disabled = true;
    buttonText.classList.add('hidden');
    buttonLoader.classList.remove('hidden');

    const formData = new FormData(form);

    try {
      const response = await fetch("/", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams(formData).toString(),
      });

      if (response.ok) {
        showModal(true);
      } else {
        showModal(false);
      }
    } catch (error) {
      showModal(false);
    } finally {
      submitButton.disabled = false;
      buttonText.classList.remove('hidden');
      buttonLoader.classList.add('hidden');
    }
  });

  // Close modal when clicking backdrop
  modal.addEventListener('click', (e) => {
    const dialogDimensions = modal.getBoundingClientRect();
    if (
      e.clientX < dialogDimensions.left ||
      e.clientX > dialogDimensions.right ||
      e.clientY < dialogDimensions.top ||
      e.clientY > dialogDimensions.bottom
    ) {
      modal.close();
    }
  });
</script>
