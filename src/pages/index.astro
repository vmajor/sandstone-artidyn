import Hero from "@/components/landing/Hero.astro";
import Intro from "@/components/landing/Intro.astro";
import ProductPreview from "@/components/landing/ProductPreview.astro";
import Stats from "@/components/landing/Stats.astro";
import SolutionsPreview from "@/components/landing/SolutionsPreview.astro";
import Philosophy from "@/components/landing/Philosophy.astro";
